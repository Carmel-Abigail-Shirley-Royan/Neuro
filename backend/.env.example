# NeuroGuard Environment Variables
# Copy to .env and fill in your values

# JWT Secret (change this in production!)
JWT_SECRET=neuroguard-super-secret-jwt-key-2024

# Serial Port (Arduino)
# Windows: COM3, COM4, etc.
# Linux/Mac: /dev/ttyUSB0, /dev/tty.usbmodem1101
SERIAL_PORT=COM3
SERIAL_BAUDRATE=9600

# ML Model Path
MODEL_PATH=lgblarge_scaler.pkl

# Twilio (for SMS/Call alerts)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# TwiML URL for automated voice calls
TWIML_URL=http://demo.twilio.com/docs/voice.xml
